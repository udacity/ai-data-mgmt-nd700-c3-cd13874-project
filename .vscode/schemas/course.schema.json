{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Course",
    "type": "object",
    "required": ["type"],
    "properties": {
      "type": {
        "type": "string",
        "const": "Course"
      },
      "system": {
        "$ref": "./common.schema.json#/definitions/system"
      },
      "guidance": {
        "$ref": "./common.schema.json#/definitions/guidance"
      } ,
      "spec": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "description": "The title of the node"
          },
          "summary": {
            "type": "string",
            "description": "Course summary"
          }
        },
        "additionalProperties": false
      },
      "pulled": {
        "type": "object",
        "properties": {
          "duration": {
            "type": "integer",
            "description": "The expected length of the pulled course in minutes",
            "minimum": 0
          }
        },
        "additionalProperties": false
      }
    },
    "additionalProperties": false
  }