{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Concept",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": {
      "type": "string",
      "const": "Concept"
    },
    "system": {
      "$ref": "./common.schema.json#/definitions/system"
    },
    "guidance": {
      "$ref": "./common.schema.json#/definitions/guidance"
    },
    "spec": {
      "type": "object",
      "required": ["title"],
      "properties": {
        "title": {
          "type": "string",
          "description": "The title of the concept"
        }
      }
    },
    "atoms": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "$ref": "./atoms/checkbox-quiz-atom.schema.json"
          },
          {
            "$ref": "./atoms/embedded-frame-atom.schema.json"
          },
          {
            "$ref": "./atoms/image-atom.schema.json"
          },
          {
            "$ref": "./atoms/matching-quiz-atom.schema.json"
          },
          {
            "$ref": "./atoms/quiz-atom.schema.json"
          },
          {
            "$ref": "./atoms/radio-quiz-atom.schema.json"
          },
          {
            "$ref": "./atoms/reflect-atom.schema.json"
          },
          {
            "$ref": "./atoms/task-list-atom.schema.json"
          },
          {
            "$ref": "./atoms/text-atom.schema.json"
          }, 
          {
            "$ref": "./atoms/validated-quiz-atom.schema.json"
          },
          {
            "$ref": "./atoms/video-atom.schema.json"
          },
          {
            "$ref": "./atoms/workspace-atom.schema.json"
          }
        ]
      }
    },
    "additionalProperties": false
  }
}