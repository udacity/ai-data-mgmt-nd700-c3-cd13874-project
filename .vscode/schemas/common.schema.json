{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "definitions": {
    "system": {
      "type": "object",
      "properties": {
        "id": {
          "type": "integer",
          "description": "The id of the node"
        },
        "branch_id": {
          "type": "integer",
          "description": "The id of the branch the node belongs to"
        },
        "previous_updated_at": {
          "type": "string",
          "description": "The previous updated at of the node"
        }
      },
      "additionalProperties": false
    },
    "guidance": {
      "type": "object",
      "properties": {
        "slug": {
          "type": "string",
          "description": "Filename-safe slug used for directory naming (preferred over spec.title slugification)"
        }
      },
      "additionalProperties": true,
      "description": "Namespace for arbitrary guidance properties"
    }
  }
}
