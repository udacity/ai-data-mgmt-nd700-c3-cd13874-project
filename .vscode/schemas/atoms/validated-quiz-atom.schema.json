{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ValidatedQuizAtom",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": { "type": "string", "const": "ValidatedQuizAtom" },
    "system": {
      "$ref": "../common.schema.json#/definitions/system"
    },
    "guidance": {
      "$ref": "../common.schema.json#/definitions/guidance"
    },
    "spec": {
      "type": "object",
      "required": ["question"],
      "additionalProperties": false,
      "properties": {
        "question": {
          "type": "object",
          "required": ["prompt", "correct_feedback", "default_feedback", "matchers"],
          "properties": {
            "prompt": {
              "type": "string",
              "description": "Prompt Question"
            },
            "correct_feedback": {
              "type": "string",
              "description": "Feedback for when the user answers correctly"
            },
            "default_feedback": {
              "type": "string",
              "description": "Default feedback for when the user answers incorrectly and there is no incorrect_feedback on the matcher itself"
            },
            "matchers": {
              "type": "array",
              "description": "Matchers for validating user responses",
              "items": {
                "oneOf": [
                  {
                    "type": "object",
                    "required": ["semantic_type", "is_correct", "expression"],
                    "properties": {
                      "semantic_type": {
                        "type": "string",
                        "const": "RegexMatcher",
                        "description": "The type of this matcher"
                      },
                      "is_correct": {
                        "type": "boolean",
                        "description": "Whether this matcher represents a correct response"
                      },
                      "incorrect_feedback": {
                        "type": "string",
                        "description": "The response when this matcher is matched and is_correct is false"
                      },
                      "expression": {
                        "type": "string",
                        "description": "The regular expression to match against"
                      },
                      "expression_description": {
                        "type": "string",
                        "description": "An optional, human readable description of the regular expression to match against"
                      },
                      "flags": {
                        "type": "string",
                        "description": "Regex flags to use when matching"
                      }
                    },
                    "additionalProperties": false
                  }
                ]
              },
              "minItems": 1
            }
          },
          "additionalProperties": false
        }
      }
    }
  }
}
