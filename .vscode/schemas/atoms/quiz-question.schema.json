{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Quiz Question Definitions",
  "definitions": {
    "Question": {
      "oneOf": [
        { "$ref": "#/definitions/TextQuestion" },
        { "$ref": "#/definitions/ImageFormQuestion" },
        { "$ref": "#/definitions/ProgrammingQuestion" },
        { "$ref": "#/definitions/IFrameQuestion" },
        { "$ref": "#/definitions/CodeGradedQuestion" }
      ]
    },
    "TextQuestion": {
      "type": "object",
      "properties": {
        "text": { "type": "string" },
        "title": { "type": "string" },
        "semantic_type": { "const": "TextQuestion" }
      }
    },
    "ImageFormQuestion": {
      "type": "object",
      "properties": {
        "widgets": {
          "type": "array",
          "items": { "$ref": "#/definitions/Widget" }
        },
        "alt_text": { "type": "string" },
        "title": { "type": "string" },
        "semantic_type": { "const": "ImageFormQuestion" }
      }
    },
    "ProgrammingQuestion": {
      "type": "object",
      "properties": {
        "initial_code_files": {
          "type": "array",
          "items": { "$ref": "#/definitions/CodeFile" }
        },
        "evaluator": { "$ref": "#/definitions/Evaluator" },
        "title": { "type": "string" },
        "semantic_type": { "const": "ProgrammingQuestion" }
      }
    },
    "IFrameQuestion": {
      "type": "object",
      "properties": {
        "initial_code_files": {
          "type": "array",
          "items": { "$ref": "#/definitions/CodeFile" }
        },
        "js_application": { "type": "string" },
        "html_body": { "type": "string" },
        "external_iframe_uri": { "type": "string" },
        "title": { "type": "string" },
        "semantic_type": { "const": "IFrameQuestion" }
      }
    },
    "CodeGradedQuestion": {
      "type": "object",
      "properties": {
        "evaluator": { "$ref": "#/definitions/Evaluator" },
        "prompt": { "type": "string" },
        "title": { "type": "string" },
        "semantic_type": { "const": "CodeGradedQuestion" }
      }
    },
    "Evaluator": {
      "type": "object",
      "description": "Stores information about how to evaluate quiz",
      "properties": {
        "model": { "type": "string" },
        "execution_language": { "type": "string" },
        "executor_grading_code": { "type": "string" },
        "gae_grading_code": { "type": "string" }
      }
    },
    "Widget": {
      "type": "object",
      "description": "The widgets for an image form question",
      "properties": {
        "group": { "type": "string" },
        "initial_value": { "type": "string" },
        "label": { "type": "string" },
        "marker": { "type": "string" }
      }
    },
    "CodeFile": {
      "type": "object",
      "description": "Initial code files for programming questions",
      "properties": {
        "name": { "type": "string" },
        "text": { "type": "string" }
      }
    }
  }
}

