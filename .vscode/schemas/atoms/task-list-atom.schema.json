{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskListAtom",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": { "type": "string", "const": "TaskListAtom" },
    "system": {
      "$ref": "../common.schema.json#/definitions/system"
    },
    "guidance": {
      "$ref": "../common.schema.json#/definitions/guidance"
    },
    "spec": {
      "type": "object",
      "required": ["tasks", "positive_feedback"],
      "additionalProperties": false,
      "properties": {
        "description": {
          "type": "string",
          "description": "Optional description field for explaining tasks to students"
        },
        "tasks": {
          "type": "array",
          "description": "Array of tasks for students",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "positive_feedback": {
          "type": "string",
          "description": "Positive feedback to show to the students after checking all tasks as done"
        }
      }
    }
  }
}
