{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RadioQuizAtom",
  "type": "object",
  "required": ["type"],
  "properties": {
    "type": { "type": "string", "const": "RadioQuizAtom" },
    "system": {
      "$ref": "../common.schema.json#/definitions/system"
    },
    "guidance": {
      "$ref": "../common.schema.json#/definitions/guidance"
    },
    "spec": {
      "type": "object",
      "required": ["question"],
      "additionalProperties": false,
      "properties": {
        "question": {
          "type": "object",
          "required": ["prompt", "answers"],
          "properties": {
            "prompt": { "type": "string" },
            "correct_feedback": { "type": "string" },
            "default_feedback": { "type": "string" },
            "answers": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["id", "is_correct", "text"],
                "properties": {
                  "id": { "type": "string" },
                  "text": { "type": "string" },
                  "incorrect_feedback": { "type": "string" },
                  "is_correct": { "type": "boolean" }
                },
                "additionalProperties": false
              }
            },
            "always_correct": { "type": "boolean" }
          },
          "additionalProperties": false
        }
      }
    }
  }
}

