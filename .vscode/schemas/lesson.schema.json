{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Lesson",
    "type": "object",
    "required": ["type"],
    "properties": {
      "type": {
        "type": "string",
        "const": "Lesson"
      },
      "system": {
        "$ref": "./common.schema.json#/definitions/system"
      },
      "guidance": {
        "$ref": "./common.schema.json#/definitions/guidance"
      },
      "spec": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "description": "The title of the lesson"
          },
          "summary": {
            "type": "string",
            "description": "The summary of the lesson"
          }
        },
        "additionalProperties": false
      },
      "pulled": {
        "type": "object",
        "properties": {
          "duration": {
            "type": "integer",
            "description": "The expected length of the pulled lesson in minutes",
            "minimum": 0
          }
        },
        "additionalProperties": false
      },
      "project": {
        "$ref": "./project.schema.json"
      },
      "lab": {
        "$ref": "./lab.schema.json"
      }
    },
    "additionalProperties": false
  }